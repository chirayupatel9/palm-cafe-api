{
  "name": "cafe-management-server",
  "version": "1.0.0",
  "description": "Backend API for Cafe Management System",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "setup": "node setup.js",
    "create-db": "node create-database.js",
    "migrate": "node run-migrations.js",
    "migrate:status": "node -e \"require('./run-migrations').runMigrations().then(() => console.log('Migrations up to date')).catch(console.error)\"",
    "lint": "node -e \"console.log('Lint placeholder; add ESLint when ready')\"",
    "test": "cross-env NODE_ENV=test jest",
    "test:e2e": "cross-env NODE_ENV=test jest --config=jest.e2e.config.js",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:load": "node tests/load/run-load-tests.js",
    "test:stress": "cross-env NODE_ENV=test jest --config=jest.stress.config.js tests/stress",
    "test:chaos": "cross-env NODE_ENV=test jest tests/chaos --no-cov"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.3.1",
    "form-data": "^4.0.4",
    "fs-extra": "^11.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.14.2",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.6.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.14.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
